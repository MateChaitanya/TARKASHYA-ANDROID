<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Tarkashya" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#D32F2F</item>
        <item name="colorPrimaryVariant">#B71C1C</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">#D32F2F</item>
    </style>

    <style name="Theme.Tarkashya" parent="Base.Theme.Tarkashya" />

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ProfileRowStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingVertical">10dp</item>
    </style>

    <style name="ProfileLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_alignParentStart">true</item>
        <item name="android:textColor">#757575</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ProfileValueStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:textColor">#212121</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SafetyTipTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#E53935</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <style name="SafetyTipBody">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#424242</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

</resources>