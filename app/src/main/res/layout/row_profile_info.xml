<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <RelativeLayout style="@style/ProfileRowStyle">
        <TextView android:text="Full Name" style="@style/ProfileLabelStyle" />
        <TextView android:id="@+id/tvProfileFullName" android:text="Name" style="@style/ProfileValueStyle" />
    </RelativeLayout>

    <RelativeLayout style="@style/ProfileRowStyle">
        <TextView android:text="Date of Birth" style="@style/ProfileLabelStyle" />
        <TextView android:id="@+id/tvProfileDob" android:text="DOB" style="@style/ProfileValueStyle" />
    </RelativeLayout>

    <RelativeLayout style="@style/ProfileRowStyle">
        <TextView android:text="Gender" style="@style/ProfileLabelStyle" />
        <TextView android:id="@+id/tvProfileGender" android:text="Gender" style="@style/ProfileValueStyle" />
    </RelativeLayout>

    <RelativeLayout style="@style/ProfileRowStyle">
        <TextView android:text="Blood Group" style="@style/ProfileLabelStyle" />
        <TextView android:id="@+id/tvProfileBlood" android:text="Group" style="@style/ProfileValueStyle" />
    </RelativeLayout>

    <RelativeLayout style="@style/ProfileRowStyle">
        <TextView android:text="Phone Number" style="@style/ProfileLabelStyle" />
        <TextView android:id="@+id/tvProfilePhone" android:text="Phone" style="@style/ProfileValueStyle" />
    </RelativeLayout>

</LinearLayout>