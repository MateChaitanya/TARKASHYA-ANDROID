<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Emergency QR"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Anyone can scan this to help you in emergency"
        android:textSize="14sp"
        android:layout_marginBottom="30dp"/>

    <ImageView
        android:id="@+id/ivMyQrCode"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/card_bg_light"
        android:padding="10dp"
        android:elevation="4dp"/>

    <TextView
        android:id="@+id/tvQrName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="User Name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#212121"/>

    <TextView
        android:id="@+id/tvQrId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TKS-8892"
        android:textColor="#757575"/>

</LinearLayout>